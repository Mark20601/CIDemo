# Use an official PHP image with Apache pre-installed
FROM php:8.2-apache

RUN a2enmod rewrite

# 1. Install any common PHP extensions you might need (optional)
RUN docker-php-ext-install mysqli pdo pdo_mysql

# 2. Copy your project files into the web server directory
COPY . /var/www/html/

# 3. Tell Apache to listen on the port Render uses
EXPOSE 80

# 4. Start Apache in the foreground
CMD ["apache2-foreground"]